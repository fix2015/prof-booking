# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_DEBUG=true
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql://nail_user:nail_password@localhost:5432/nail_salon_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Email
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASSWORD=...
EMAIL_FROM=noreply@nailsalonplatform.com
EMAIL_FROM_NAME=NailSalon Platform

# Platform Admin
FIRST_ADMIN_EMAIL=admin@nailsalonplatform.com
FIRST_ADMIN_PASSWORD=change-in-production
