{
  "editable": true,
  "panels": [
    {
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showOptions": "current",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true, "noData": true, "normal": false, "error": true }
      }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "pg_up", "legendFormat": "PostgreSQL" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "title": "Redis Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "redis_up", "legendFormat": "Redis" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "title": "Backend Container",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "count(container_memory_usage_bytes{name=\"nail_backend\"}) or vector(0)", "legendFormat": "Backend" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "node_time_seconds - node_boot_time_seconds", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "CPU (last hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "title": "Memory (last hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["probooking", "alerts"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "ProBook — Alerts & Health",
  "uid": "probooking-alerts"
}
