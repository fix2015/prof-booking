{
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "All Container Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=~\"nail_.*\"} |= ``",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "Backend Logs (API)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=\"nail_backend\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "Backend Errors Only",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=\"nail_backend\"} |~ `(?i)(error|exception|traceback|500)`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "Celery Worker Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=\"nail_celery_worker\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "PostgreSQL Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=\"nail_postgres\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Error Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate({container=\"nail_backend\"} |~ `(?i)(error|500|exception)` [1m])) * 60",
          "legendFormat": "Errors/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["probooking", "logs"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "ProBook — Logs",
  "uid": "probooking-logs"
}
